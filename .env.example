# ============================================================================
# CryptoRSI (RSIQ Pro) — Environment Variables
# ============================================================================
# Copy this file to .env for production or .env.local for local development.
# On Render, set these as Environment Variables in the Dashboard.
# ============================================================================

# ── Database (Neon PostgreSQL) ──
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"
DATABASE_URL_UNPOOLED=""

# ── Database Provider ──
DB_PROVIDER=neon
NEXT_PUBLIC_DB_PROVIDER=neon

# ── Authentication (Better Auth) ──
# Generate a strong random secret: openssl rand -base64 48
BETTER_AUTH_SECRET="generate-a-64-char-random-string"
# MUST match your deployment URL exactly (no trailing slash)
BETTER_AUTH_URL="https://rsiq.onrender.com"
NEXT_PUBLIC_APP_URL="https://rsiq.onrender.com"

# ── Stripe (Optional) ──
STRIPE_SECRET_KEY=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_MONTHLY_PRICE_ID=""
STRIPE_YEARLY_PRICE_ID=""

# ── Admin Access ──
ALLOWED_ADMINS=""
SUPER_ADMIN_EMAIL=""

# ── Email (Resend) ──
RESEND_API_KEY=""
EMAIL_FROM="RSIQ Pro <noreply@yourdomain.com>"

# ── LLM Providers (Optional) ──
GOOGLE_GENERATIVE_AI_API_KEY=""
OPENROUTER_API_KEY=""

# ── Warm Cache (Optional) ──
WARM_SECRET=""
