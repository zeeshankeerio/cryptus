{
  "headers": [
    {
      "source": "/(manifest.json|sw.js|offline)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    },
    {
      "source": "/_next/static/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/(logo|images)/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=604800"
        }
      ]
    },
    {
      "source": "/og-image.(png|webp)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=86400, stale-while-revalidate=3600"
        }
      ]
    },
    {
      "source": "/og_RSIQ_mindscapeanalytics.png",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=86400"
        }
      ]
    }
  ],
  "regions": ["fra1"],
  "functions": {
    "app/api/screener/route.ts": {
      "maxDuration": 60
    },
    "app/api/cron/check-alerts/route.ts": {
      "maxDuration": 300
    },
    "app/api/og/[symbol]/route.tsx": {
      "maxDuration": 15
    }
  }
}
