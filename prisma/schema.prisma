generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id
  name          String
  email         String    @unique
  emailVerified Boolean   @default(false)
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  role          String?   @default("user")
  banned        Boolean?  @default(false)
  banReason     String?
  banExpires    DateTime?
  accounts      Account[]
  sessions      Session[]
  pushSubscriptions PushSubscription[]
  coinConfigs       CoinConfig[]
  alertLogs         AlertLog[]
  alertTemplates    AlertTemplate[]
  subscriptions     Subscription[]

  @@map("user")
}

model Subscription {
  id                   String    @id
  userId               String
  referenceId          String
  stripeCustomerId     String?
  stripeSubscriptionId String?
  status               String
  plan                 String
  billingInterval      String?
  periodStart          DateTime?
  periodEnd            DateTime?
  trialStart           DateTime?
  trialEnd             DateTime?
  cancelAtPeriodEnd    Boolean?  @default(false)
  canceledAt           DateTime?
  cancelAt             DateTime?
  endedAt              DateTime?
  seats                Int?
  invoiceRef           String?
  renewalNotes         String?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  user                 User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([referenceId])
  @@index([status])
  @@map("subscription")
}

model Session {
  id             String   @id
  userId         String
  token          String   @unique
  expiresAt      DateTime
  ipAddress      String?
  userAgent      String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  impersonatedBy String?
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  userId                String
  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  idToken               String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

model CoinConfig {
  id                   String   @id @default(uuid())
  userId               String
  symbol               String
  exchange             String   @default("binance")
  rsi1mPeriod          Int      @default(14)
  rsi5mPeriod          Int      @default(14)
  rsi15mPeriod         Int      @default(14)
  rsi1hPeriod          Int      @default(14)
  overboughtThreshold  Int      @default(70)
  oversoldThreshold    Int      @default(30)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  alertOn15m           Boolean  @default(false)
  alertOn1h            Boolean  @default(false)
  alertOn1m            Boolean  @default(false)
  alertOn5m            Boolean  @default(false)
  alertOnCustom        Boolean  @default(false)
  alertConfluence      Boolean  @default(false)
  alertOnStrategyShift Boolean  @default(false)
  alertOnLongCandle    Boolean  @default(false)
  alertOnVolumeSpike   Boolean  @default(false)
  longCandleThreshold  Float    @default(5.0)
  volumeSpikeThreshold Float    @default(5.0)
  priority             String   @default("medium")
  sound                String   @default("default")
  quietHoursEnabled    Boolean  @default(false)
  quietHoursStart      Int      @default(22)
  quietHoursEnd        Int      @default(8)
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, symbol])
  @@index([userId])
  @@index([symbol])
  @@map("coin_config")
}

model AlertLog {
  id        String   @id @default(uuid())
  userId    String?
  symbol    String
  exchange  String?
  timeframe String
  value     Float
  type      String
  priority  String   @default("medium")
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([userId, createdAt])

  @@map("alert_log")
}

model PushSubscription {
  id        String   @id @default(uuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("push_subscription")
}

model AlertTemplate {
  id                   String   @id @default(uuid())
  userId               String
  name                 String
  description          String?
  rsi1mPeriod          Int      @default(14)
  rsi5mPeriod          Int      @default(14)
  rsi15mPeriod         Int      @default(14)
  rsi1hPeriod          Int      @default(14)
  overboughtThreshold  Int      @default(70)
  oversoldThreshold    Int      @default(30)
  alertOn1m            Boolean  @default(false)
  alertOn5m            Boolean  @default(false)
  alertOn15m           Boolean  @default(false)
  alertOn1h            Boolean  @default(false)
  priority             String   @default("medium")
  sound                String   @default("default")
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("alert_template")
}
